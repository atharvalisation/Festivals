<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="#E5C287"
    android:layout_height="match_parent"
    tools:context=".statesfestival">
    -
    <!--Heading-->
    <TextView
        android:id="@+id/heading"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:gravity="center"
        android:background="@drawable/round_edge"
        android:layout_alignParentTop="true"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:textSize="40dp"
        android:textStyle="bold|italic"
        android:layout_centerHorizontal="true"
        android:text="Gallery"
        />

    <ScrollView
        android:layout_marginTop="15dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_below="@id/heading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/varanasi1"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/navaratri1"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/durgapuja1"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/ganeshchaturti1"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/diwali1"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/dushera"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/shivrartri1"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/indianculture"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/holi1"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:layout_gravity="center"
                android:layout_width="375dp"
                android:layout_height="200dp"
                android:src="@drawable/holi2"
                android:scaleType="fitCenter"
                />

            <ImageView
                android:id="@+id/holifestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/holifestival"/>

            <ImageView
                android:id="@+id/diwalifestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/diwalifestival"/>

            <ImageView
                android:id="@+id/duseherafestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/dusherafestival"/>

            <ImageView
                android:id="@+id/eidfestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/eidfestival"/>

            <ImageView
                android:id="@+id/christmasfestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/christmasfestival"/>

            <ImageView
                android:id="@+id/pongalfestival"
