                android:src="@drawable/baisakhifestival"/>

            <ImageView
                android:id="@+id/lohrifestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/lohrifestival"/>

            <ImageView
                android:id="@+id/easterfestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/easterfestival"/>

            <ImageView
                android:id="@+id/onamfestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/onamfestival"/>

            <ImageView
                android:id="@+id/budhapurnimafestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/budhapurnimafestival"/>

            <ImageView
                android:id="@+id/rakshabandhanfestival"
                android:layout_width="match_parent"
