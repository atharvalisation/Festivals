            <ImageView
                android:id="@+id/chhathpujafestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/chhathpujafestival"/>

            <ImageView
                android:id="@+id/mahashivratrifestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/mahashivratrifestival"/>

            <ImageView
                android:id="@+id/bihufestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/bihufestival"/>

            <ImageView
                android:id="@+id/makarsankrantifestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/makarsankrantifestival"/>

            <ImageView
                android:id="@+id/hemisfestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/hemisfestival"/>

            <ImageView
                android:id="@+id/losarfestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/losarfestival"/>

            <ImageView
                android:id="@+id/hornbillfestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/hornbillfestival"/>

            <ImageView
                android:id="@+id/saraswatipujafestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/saraswatipujafestival"/>

            <ImageView
                android:id="@+id/navaratifestival"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/navaratifestival"/>

            <ImageView
